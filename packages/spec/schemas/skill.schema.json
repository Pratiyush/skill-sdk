{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/Pratiyush/agentic-skills-framework/blob/master/packages/spec/schemas/skill.schema.json",
  "title": "SkillFrontmatter",
  "description": "YAML frontmatter schema for SKILL.md files",
  "type": "object",
  "required": ["name", "description"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[a-z0-9](?:[a-z0-9]|-(?=[a-z0-9])){0,62}[a-z0-9]?$",
      "description": "Skill name: 1-64 chars, lowercase alphanumeric + hyphens"
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024,
      "description": "What the skill does and when to use it"
    },
    "license": {
      "type": "string",
      "description": "SPDX license identifier"
    },
    "compatibility": {
      "type": "string",
      "maxLength": 500,
      "description": "Runtime requirements"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": { "type": "string" },
      "description": "Arbitrary key-value pairs"
    },
    "allowed-tools": {
      "type": "string",
      "description": "Space-delimited list of pre-approved tools"
    },
    "security": {
      "type": "object",
      "description": "Security manifest declaring capabilities, credentials, and network access",
      "properties": {
        "capabilities": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Capabilities this skill requires (e.g. read-fs, write-fs, network)"
        },
        "credentials": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Named credentials this skill needs access to"
        },
        "network": {
          "type": "object",
          "description": "Network access policy",
          "properties": {
            "allowed": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Allowed hostnames or URL prefixes"
            }
          }
        }
      }
    },
    "testing": {
      "type": "object",
      "description": "Test scenarios for this skill",
      "properties": {
        "scenarios": {
          "type": "array",
          "description": "List of test scenarios",
          "items": {
            "type": "object",
            "required": ["name", "expectedOutput"],
            "properties": {
              "name": { "type": "string" },
              "input": { "type": "string" },
              "expectedOutput": { "type": "string" }
            }
          }
        }
      }
    },
    "composition": {
      "type": "object",
      "description": "Skill composition and dependencies",
      "properties": {
        "dependencies": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Names of skills this skill depends on"
        },
        "replaces": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Names of skills this skill replaces"
        }
      }
    },
    "tools": {
      "type": "object",
      "description": "Tool bindings and dependencies",
      "properties": {
        "dependencies": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Tools this skill depends on"
        },
        "bindings": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Specific tool bindings"
        }
      }
    }
  },
  "additionalProperties": false
}
