{
  "name": "@skillscraft/spec",
  "version": "0.9.0",
  "description": "TypeScript types and JSON schemas for the Agent Skills specification",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "schemas"],
  "scripts": {
    "build": "tsup",
    "test": "echo 'no tests yet'",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "vitest": "^3.1.0",
    "eslint": "^9.24.0",
    "typescript": "^5.8.0",
    "@types/node": "^22.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Pratiyush/agentic-skills-framework",
    "directory": "packages/spec"
  },
  "keywords": ["agent-skills", "agentskills", "skill-spec", "ai-agents", "typescript"]
}
