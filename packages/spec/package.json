{
  "name": "@skillscraft/spec",
  "version": "0.9.0",
  "description": "TypeScript types and JSON schemas for the Agent Skills specification",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./schemas/skill.schema.json": "./schemas/skill.schema.json"
  },
  "files": ["dist", "schemas"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "vitest": "^4.1.8",
    "eslint": "^9.24.0",
    "typescript": "^6.0.3",
    "@types/node": "^25.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Pratiyush/skill-sdk",
    "directory": "packages/spec"
  },
  "keywords": ["agent-skills", "agentskills", "skill-spec", "ai-agents", "typescript"]
}
