{
  "name": "@skillscraft/cli",
  "version": "0.9.0",
  "description": "CLI for building, validating, and linting Agent Skills",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "skill": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "templates"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@skillscraft/core": "workspace:*",
    "@skillscraft/spec": "workspace:*",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "vitest": "^4.1.8",
    "eslint": "^9.24.0",
    "typescript": "^6.0.3",
    "@types/node": "^25.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Pratiyush/skill-sdk",
    "directory": "packages/cli"
  },
  "keywords": ["agent-skills", "cli", "skill-builder", "validator", "linter"]
}
